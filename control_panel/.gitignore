# ==============================================================================
# --- Version Control System ---
# ==============================================================================
# Ignore other VCS directories
.svn
.hgsvn

# ==============================================================================
# --- Python Virtual Environments ---
# ==============================================================================
# Standard virtual environment directories
.env/
.venv/
env/
venv/
lib/
bin/
include/
.Python/
/pythonenv*/

# ==============================================================================
# --- Python Artifacts ---
# ==============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.dll

# Distribution / packaging
build/
dist/
.eggs/
*.egg-info/
pip-wheel-metadata/

# Autogenerated version file (e.g., by setuptools_scm)
src/_pytest/_version.py

# ==============================================================================
# --- IDEs, Editors, and OS-specific files ---
# ==============================================================================
# IDEs
.idea/
.vscode/
.project
.pydevproject
.ropeproject
.settings/

# Editors
*.swp
*~
*.orig

# macOS
**/.DS_Store

# ==============================================================================
# --- Testing & Coverage ---
# ==============================================================================
.cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.hypothesis/
.pytest_cache/
pytestdebug.log

# Insta snapshots
*.pending-snap

# ==============================================================================
# --- Other Tools ---
# ==============================================================================
# MyPy
.mypy_cache/

# Tox
.tox/

# Documentation (Sphinx / MkDocs)
doc/*/_build/
doc/*/.doctrees/
site/

# Rust / Cargo
debug/
target/
target-alpine/
**/*.rs.bk
*.pdb

# Node.js
**/node_modules/

# Profiling
flamegraph.svg
perf.data
perf.data.old
profile.json

# ==============================================================================
# --- Project Specific ---
# ==============================================================================
# As found in original .gitignore
issue/
3rdparty/
.python-version
trigger.txt
